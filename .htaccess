 server {
  listen 80;
  server_name ezhong.co www.ezhong.co;
  root /www/wwwroot/www.ezhong.co;   # ← 按你的路径改

  index index.php index.html;

  # 静态缓存
  location ~* \.(?:jpg|jpeg|png|webp|gif|css|js|ico|svg|mp4)$ {
    expires 30d;
    access_log off;
  }

  # 禁止在静态目录执行 PHP
  location ~ ^/(assets|vendor)/.*\.php$ { return 403; }

  # PHP
  location ~ \.php$ {
    include fastcgi_params;
    fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
    fastcgi_pass unix:/run/php/php-fpm.sock;  # 或 127.0.0.1:9000
  }

  # 404 交给 index.php（保留真实状态码由应用层设置）
  error_page 404 = /index.php?p=404;
}
